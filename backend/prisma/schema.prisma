generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ELEVE
  PARENT
}

model User {
  id           String   @id @default(uuid())
  username     String?  @unique
  name         String
  email        String?  @unique
  passwordHash String   @map("password_hash")
  avatarUrl    String?  @map("avatar_url")
  role         Role     @default(ELEVE)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  subjects         Subject[]
  revisionSessions RevisionSession[]
  exams            Exam[]
  bulletins        Bulletin[]

  @@map("users")
}

model Subject {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  color     String   @default("#6366f1")
  icon      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessons          Lesson[]
  assessments      Assessment[]
  bulletinSubjects BulletinSubject[]

  @@map("subjects")
}

model Lesson {
  id             String    @id @default(uuid())
  subjectId      String    @map("subject_id")
  title          String
  order          Int       @default(0)
  trimester      Int       @default(1)
  color          String    @default("#3b82f6")
  contentPercent Int       @default(0) @map("content_percent")
  screenshotUrl  String?   @map("screenshot_url")
  isRevised      Boolean   @default(false) @map("is_revised")
  revisedAt      DateTime? @map("revised_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  subject          Subject           @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  revisionSessions RevisionSession[]
  resources        LessonResource[]
  assessments      AssessmentLesson[]

  @@map("lessons")
}

enum ResourceType {
  LINK
  DOC
  IMAGE
}

model LessonResource {
  id        String       @id @default(uuid())
  lessonId  String       @map("lesson_id")
  type      ResourceType
  title     String
  url       String
  mimeType  String?      @map("mime_type")
  fileSize  Int?         @map("file_size")
  order     Int          @default(0)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("lesson_resources")
}

model Assessment {
  id        String    @id @default(uuid())
  subjectId String    @map("subject_id")
  trimester Int
  kind      String    // DC1, DC2, DS1
  date      DateTime? // date prévue du devoir
  isPast    Boolean   @default(false) @map("is_past")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  subject Subject            @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  lessons AssessmentLesson[]
  resources AssessmentResource[]

  @@unique([subjectId, trimester, kind])
  @@map("assessments")
}

model AssessmentResource {
  id           String       @id @default(uuid())
  assessmentId String       @map("assessment_id")
  type         ResourceType
  title        String
  url          String
  mimeType     String?      @map("mime_type")
  fileSize     Int?         @map("file_size")
  order        Int          @default(0)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@map("assessment_resources")
}

model AssessmentLesson {
  assessmentId String @map("assessment_id")
  lessonId     String @map("lesson_id")

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  lesson     Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@id([assessmentId, lessonId])
  @@map("assessment_lessons")
}

model Exam {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  subject   String
  date      String   // YYYY-MM-DD
  detail    String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("exams")
}

model Bulletin {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  schoolYear     String   @map("school_year") // ex: "2025/2026"
  trimester      Int      // 1 | 2 | 3
  className      String?  @map("class_name") // ex: "9ème année enseignement de base 1"
  classSize      Int?     @map("class_size") // effectif (nombre d'élèves)
  rank           Int?     // rang final dans la classe
  generalAverage Decimal? @map("general_average") @db.Decimal(5, 2) // moyenne du trimestre (calculée)
  isProjection   Boolean  @default(false) @map("is_projection")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjects BulletinSubject[]

  @@unique([userId, schoolYear, trimester, isProjection])
  @@map("bulletins")
}

model BulletinSubject {
  id             String   @id @default(uuid())
  bulletinId     String   @map("bulletin_id")
  subjectId      String?  @map("subject_id") // lien optionnel vers Subject (création auto si manquant)
  name           String   // nom affiché (FR canonique)
  coefficient    Decimal  @db.Decimal(4, 2)
  order          Int      @default(0)
  oral           Decimal? @db.Decimal(5, 2) // شفاهي
  tp             Decimal? @db.Decimal(5, 2) // أشغال تطبيقية
  examenEcrit    Decimal? @map("examen_ecrit") @db.Decimal(5, 2) // اختبار كتابي
  dc1            Decimal? @db.Decimal(5, 2) // فرض مراقبة 1
  dc2            Decimal? @db.Decimal(5, 2) // فرض مراقبة 2
  devoirSynthese Decimal? @map("devoir_synthese") @db.Decimal(5, 2) // فرض تأليفي
  moyenne        Decimal? @db.Decimal(5, 2) // معدل الثلاثي
  rank           Int? // الرتبة
  total          Decimal? @db.Decimal(6, 2) // الحاصل = moyenne × coef
  exempted       Boolean  @default(false) // معفى
  teacherNote    String?  @map("teacher_note") // ملاحظات الأستاذ
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  bulletin Bulletin @relation(fields: [bulletinId], references: [id], onDelete: Cascade)
  subject  Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  @@unique([bulletinId, name])
  @@map("bulletin_subjects")
}

model RevisionSession {
  id        String  @id @default(uuid())
  userId    String  @map("user_id")
  date      String  // YYYY-MM-DD
  startTime String? @map("start_time") // HH:MM (optional — if null, unscheduled)
  duration  Int     @default(60) // minutes
  subject   String  // subject name (free text, matches timetable subjects)
  lessonId  String? @map("lesson_id")
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  @@map("revision_sessions")
}
